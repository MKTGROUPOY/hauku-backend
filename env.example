# Hauku Backend — ympäristömuuttujat
# Kopioi tämä .env.local -tiedostoksi kehitykseen
# Tuotannossa aseta nämä Vercel Dashboard → Settings → Environment Variables

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Malli: claude-sonnet-4-6 tai claude-haiku-4-5-20251001 (halvempi)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Shopify ───────────────────────────────────────────────────────────────────
# Storefront API token (JULKINEN – ei tarvitse salata, mutta pidä Vercelissä)
# Shopify Admin → Apps → Storefront API → Manage private apps → Create token
# Tarvittavat oikeudet: read_products
SHOPIFY_STOREFRONT_TOKEN=shpat_...

# Shopify-kaupan domain ilman https://
SHOPIFY_DOMAIN=ruokakoiralle.myshopify.com

# ── System prompt ─────────────────────────────────────────────────────────────
# Pitkä teksti – helpointa asettaa Vercelissä muuttujana tai lukea tiedostosta
# Kopioi hauku-widget.html:n hwSys-scriptin sisältö tähän
SYSTEM_PROMPT="Olet Hauku, RuokaKoiralle.fi:n koiranruoka-asiantuntija..."

# ── CORS ─────────────────────────────────────────────────────────────────────
# Salli vain oma domain tuotannossa (pilkulla erotettu lista)
# Kehityksessä: * sallii kaikki
ALLOWED_ORIGINS=https://ruokakoiralle.fi,https://www.ruokakoiralle.fi
